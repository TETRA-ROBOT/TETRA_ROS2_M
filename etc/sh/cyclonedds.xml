<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
    <Domain id="any">
	<General>
	    <AllowMulticast>true</AllowMulticast>
	</General>
	<Discovery>
	    <ParticipantIndex>auto</ParticipantIndex>
	    <MaxAutoParticipantIndex>1000</MaxAutoParticipantIndex>
	</Discovery>
        <Internal>
            <SocketReceiveBufferSize min="10MB"/>
        </Internal>
    </Domain>
</CycloneDDS>
